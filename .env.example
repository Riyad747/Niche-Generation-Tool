# ─── Database (Postgres + pgvector) ───────────────────────────────
# Neon / Supabase connection string. Use the pooled URL for the app,
# direct URL for migrations.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ─── Clerk auth ───────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ─── Redis + jobs (Upstash) ───────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."
QSTASH_TOKEN="..."
QSTASH_CURRENT_SIGNING_KEY="..."
QSTASH_NEXT_SIGNING_KEY="..."

# ─── AI providers ─────────────────────────────────────────────────
# OPTIONAL: users can add their own keys in-app (Settings → API keys).
# Set these to provide a server-wide fallback for users who haven't added theirs.
# GEMINI (free tier) runs the whole app on its own — https://aistudio.google.com/apikey
GEMINI_API_KEY="AIza..."
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# Optional: 32+ char secret used to encrypt user-provided API keys at rest.
# If unset, the app derives an encryption key from CLERK_SECRET_KEY.
APP_ENCRYPTION_KEY=""

# ─── Object storage (uploads) ─────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
